generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  operator
}

enum AppModule {
  links
  workspace_users
  s3_manager
  password_vault
}

enum LinkType {
  URL
  FILE
  WHATSAPP
}

model User {
  id         String      @id @default(cuid())
  googleId   String      @unique
  email      String      @unique
  name       String
  picture    String?
  role         UserRole           @default(operator)
  createdAt    DateTime           @default(now())
  shortLinks   ShortLink[]
  auditLogs    AdminAuditLog[]    @relation("ActorAuditLogs")
  moduleAccess UserModuleAccess[]
}

model UserModuleAccess {
  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  module AppModule

  @@id([userId, module])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorId     String
  actor       User     @relation("ActorAuditLogs", fields: [actorId], references: [id])
  actorEmail  String
  action      String
  targetEmail String?
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model ShortLink {
  id          String   @id @default(cuid())
  slug        String   @unique
  targetUrl   String
  type        LinkType @default(URL)
  s3Key       String?
  fileName    String?
  mimeType    String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  clickCount  Int      @default(0)
  tags        String[] @default([])

  @@index([createdById])
  @@index([tags], type: Gin)
}
