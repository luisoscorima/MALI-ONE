generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  operator
}

enum AppModule {
  links
  workspace_users
  s3_manager
  password_vault
  widget_educacion
  widget_biblioteca
  widget_museo
  widget_pam
  screen_cast
  bsale_reports
  mailing
  newsletters
  crm_pam
}

enum ScreenCastMediaType {
  image
  video
  gif
}

enum ScreenCastOrientation {
  LANDSCAPE
  PORTRAIT
}

enum PamEmailStatus {
  PENDIENTE
  ENVIADO
  ERROR_DATOS
  ERROR_TEMP
}

enum PamMpStatus {
  pending
  in_process
  approved
  authorized
  rejected
  cancelled
  refunded
  charged_back
}

enum LinkType {
  URL
  FILE
  WHATSAPP
}

model User {
  id             String      @id @default(cuid())
  googleId       String      @unique
  email          String      @unique
  name           String
  picture        String?
  role           UserRole           @default(operator)
  qrDefaultStyle Json?
  createdAt      DateTime           @default(now())
  shortLinks     ShortLink[]
  auditLogs      AdminAuditLog[]    @relation("ActorAuditLogs")
  moduleAccess   UserModuleAccess[]
  newsletters    Newsletter[]
  emailCampaigns EmailCampaign[]
}

model UserModuleAccess {
  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  module AppModule

  @@id([userId, module])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorId     String
  actor       User     @relation("ActorAuditLogs", fields: [actorId], references: [id])
  actorEmail  String
  action      String
  targetEmail String?
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model ShortLink {
  id          String      @id @default(cuid())
  slug        String      @unique
  targetUrl   String
  type        LinkType    @default(URL)
  s3Key       String?
  fileName    String?
  mimeType    String?
  qrStyle     Json?
  qrLogoKey   String?
  createdById String
  createdBy   User        @relation(fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())
  clickCount  Int         @default(0)
  tags        String[]    @default([])
  clicks      LinkClick[]

  @@index([createdById])
  @@index([tags], type: Gin)
}

model LinkClick {
  id         String    @id @default(cuid())
  linkId     String
  link       ShortLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  clickedAt  DateTime  @default(now())
  userAgent  String?
  deviceType String
  os         String?
  browser    String?

  @@index([linkId, clickedAt])
  @@index([linkId, deviceType])
}

model EducacionWidgetSettings {
  id              String   @id @default("default")
  whatsapp        String
  telefono        String
  email           String
  emailVirtual    String
  soporteVirtual  String
  imageRectangulo String
  imageWhatsapp   String
  imageCirculo    String
  imageCorreo     String
  imageMarker     String
  mapsApiKey       String?
  googleCalendarId String?
  updatedAt        DateTime @updatedAt
}

model EducacionDistrict {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  sortOrder Int             @default(0)
  sedes     EducacionSede[]
}

model EducacionSede {
  id             String             @id @default(cuid())
  slug           String             @unique
  nombre         String
  direccion      String?
  lat            Float?
  lng            Float?
  horarioHtml    String?            @db.Text
  brochureUrl    String
  districtId     String?
  district       EducacionDistrict? @relation(fields: [districtId], references: [id], onDelete: SetNull)
  showOnMap      Boolean            @default(true)
  sortOrder      Int                @default(0)
  activo         Boolean            @default(true)

  @@index([districtId])
}

model EducacionSelectorSede {
  id          String  @id @default(cuid())
  slug        String  @unique
  nombre      String
  brochureUrl String
  icon        String  @default("location_on")
  sortOrder   Int     @default(0)
  activo      Boolean @default(true)
}

model EducacionPopupSettings {
  id                 String   @id @default("default")
  activo             Boolean  @default(false)
  imagenUrl          String
  imagenLinkUrl      String?
  imagenTarget       String   @default("_blank")
  titulo             String?
  botonTexto         String
  botonUrl           String
  botonTarget        String   @default("_blank")
  showOnce           Boolean  @default(false)
  delayMs            Int      @default(800)
  animationSpeedMs   Int      @default(300)
  scheduleEnabled    Boolean  @default(false)
  scheduleDateStart  String?
  scheduleDateEnd    String?
  scheduleTimeStart  String?
  scheduleTimeEnd    String?
  scheduleTimezone   String   @default("America/Lima")
  updatedAt          DateTime @updatedAt
}

model MuseoPopupSettings {
  id                 String   @id @default("default")
  activo             Boolean  @default(false)
  imagenUrl          String
  imagenLinkUrl      String?
  imagenTarget       String   @default("_blank")
  titulo             String?
  botonTexto         String
  botonUrl           String
  botonTarget        String   @default("_blank")
  showOnce           Boolean  @default(false)
  delayMs            Int      @default(800)
  animationSpeedMs   Int      @default(300)
  scheduleEnabled    Boolean  @default(false)
  scheduleDateStart  String?
  scheduleDateEnd    String?
  scheduleTimeStart  String?
  scheduleTimeEnd    String?
  scheduleTimezone   String   @default("America/Lima")
  updatedAt          DateTime @updatedAt
}

model EducacionAliado {
  id        String  @id @default(cuid())
  nombre    String
  imageUrl  String
  categoria String
  url       String?
  sortOrder Int     @default(0)
  activo    Boolean @default(true)
}

model BibliotecaCarouselItem {
  id              String  @id @default(cuid())
  title           String
  subtitle        String?
  descriptionHtml String  @db.Text
  link            String
  imageSrc        String
  imageAlt        String
  backgroundSrc   String
  sortOrder       Int     @default(0)
  activo          Boolean @default(true)
}

model BibliotecaCarouselSettings {
  id          String   @id @default("default")
  headerTitle String   @default("CONOCE NUESTRAS NUEVAS ADQUISICIONES")
  headerColor String   @default("#e82323")
  updatedAt   DateTime @updatedAt
}

model PamWidgetSettings {
  id        String   @id @default("default")
  benefits  Json
  notes     Json
  updatedAt DateTime @updatedAt
}

model PamPlan {
  id              String  @id @default(cuid())
  slug            String  @unique
  name            String
  color           String
  exclusive       Boolean @default(false)
  sortOrder       Int     @default(0)
  monthlyPrice    String
  monthlyDuration String
  monthlyCheckout String
  monthlyValues   Json
  yearlyPrice     String
  yearlyDuration  String
  yearlyCheckout  String
  yearlyValues    Json
  activo          Boolean @default(true)
}

/// Catálogo de medios de pago (editable en CRM PAM). Solo Mercado Pago es sistema/default del widget.
model PamPaymentMethod {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  active    Boolean  @default(true)
  /// No se puede borrar (p. ej. mercado_pago).
  system    Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortOrder])
}

model PamRegistration {
  /// Ledger de pago/membresía (MP, welcome, expiry). La persona vive en WhatsApp CRM.
  id               String          @id @default(cuid())
  createdAt        DateTime        @default(now())
  nombres          String
  apellidos        String
  dni              String
  celular          String
  correo           String
  direccion        String?
  ciudad           String?
  distrito         String?
  genero           String?
  fechaNacimiento  String?
  comoTeEnteraste  String?
  plan             String
  frecuencia       String
  checkoutUrl      String?
  /// Slug de PamPaymentMethod (default mercado_pago en widget).
  paymentMethod    String          @default("mercado_pago")
  aceptaPrivacidad Boolean
  mpStatus         PamMpStatus?
  welcomeEmail     PamEmailStatus  @default(PENDIENTE)
  expiryNotice     PamEmailStatus  @default(PENDIENTE)
  expiryDate       DateTime?

  @@index([correo])
  @@index([mpStatus])
  @@index([celular])
  @@index([paymentMethod])
}

model ScreenCastPlaylist {
  id        String                   @id @default(cuid())
  name      String
  activo    Boolean                  @default(true)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt
  items     ScreenCastPlaylistItem[]
  monitors  ScreenCastMonitor[]
}

model ScreenCastPlaylistItem {
  id         String              @id @default(cuid())
  playlistId String
  playlist   ScreenCastPlaylist  @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  mediaUrl   String
  mediaType  ScreenCastMediaType
  durationMs Int                 @default(10000)
  sortOrder  Int                 @default(0)
  activo     Boolean             @default(true)

  @@index([playlistId, sortOrder])
}

model ScreenCastMonitor {
  id          String                @id @default(cuid())
  screenKey   String                @unique
  name        String
  location    String?
  orientation ScreenCastOrientation @default(LANDSCAPE)
  playlistId  String?
  playlist    ScreenCastPlaylist?   @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  lastSeenAt  DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([playlistId])
}

enum NewsletterStatus {
  draft
  published
}

enum EmailCampaignStatus {
  draft
  scheduled
  queued
  sending
  completed
  failed
}

enum EmailSendStatus {
  pending
  sent
  failed
}

enum EmailEventType {
  open
  click
}

model Newsletter {
  id          String           @id @default(cuid())
  slug        String           @unique
  title       String
  subject     String
  htmlBody    String           @db.Text
  /// GrapesJS project JSON for re-editing the visual design.
  designJson  String?          @db.Text
  status      NewsletterStatus @default(draft)
  createdById String
  createdBy   User             @relation(fields: [createdById], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  campaigns   EmailCampaign[]

  @@index([createdById])
  @@index([status])
}

model EmailCampaign {
  id                       String              @id @default(cuid())
  newsletterId             String
  newsletter               Newsletter          @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  name                     String
  status                   EmailCampaignStatus @default(draft)
  audienceArea             String              @default("pam")
  /// Legacy singular; prefer audienceSegments.
  audienceSegment          String?
  audienceSegments         String[]            @default([])
  audienceExcludeSegments  String[]            @default([])
  audienceAttrKey          String?
  audienceAttrValue        String?
  totalRecipients          Int                 @default(0)
  sentCount                Int                 @default(0)
  openCount                Int                 @default(0)
  clickCount               Int                 @default(0)
  errorCount               Int                 @default(0)
  scheduledAt              DateTime?
  startedAt                DateTime?
  completedAt              DateTime?
  createdById              String
  createdBy                User                @relation(fields: [createdById], references: [id])
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  sends                    EmailSend[]
  events                   EmailEvent[]

  @@index([newsletterId])
  @@index([createdById])
  @@index([status])
  @@index([scheduledAt])
}

model EmailSend {
  id           String          @id @default(cuid())
  campaignId   String
  campaign     EmailCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  email        String
  contactId    Int?
  name         String?
  status       EmailSendStatus @default(pending)
  openToken    String          @unique @default(cuid())
  sesMessageId String?
  error        String?
  sentAt       DateTime?
  createdAt    DateTime        @default(now())
  events       EmailEvent[]

  @@index([campaignId])
  @@index([email])
}

model EmailEvent {
  id         String         @id @default(cuid())
  campaignId String
  campaign   EmailCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sendId     String?
  send       EmailSend?     @relation(fields: [sendId], references: [id], onDelete: SetNull)
  type       EmailEventType
  url        String?
  userAgent  String?
  createdAt  DateTime       @default(now())

  @@index([campaignId, createdAt])
  @@index([sendId])
  @@index([type])
}

