# App
NODE_ENV=production
APP_URL=https://dev.mali.pe
# Orígenes permitidos para widgets embebidos (fetch cross-origin desde sitios públicos)
CORS_ORIGINS=https://educacion.mali.pe,https://biblioteca.mali.pe,https://mali.pe
API_PORT=3000
TRUST_PROXY=true

# Solo desarrollo local con `docker compose up` (sin docker-compose.prod.yml)
WEB_PORT=8080

# Auth Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://dev.mali.pe/api/auth/google/callback
ALLOWED_DOMAIN=mali.pe
JWT_SECRET=change-me-to-a-long-random-string
COOKIE_DOMAIN=dev.mali.pe
BOOTSTRAP_ADMIN_EMAIL=loscorima@mali.pe

# Google Admin SDK (Service Account + Domain-Wide Delegation)
# Monta toda la carpeta secrets/ en /run/secrets dentro del contenedor api
GOOGLE_SECRETS_DIR=./secrets
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/run/secrets/google-sa.json
GOOGLE_ADMIN_IMPERSONATE=admin@mali.pe

# Database
DATABASE_URL=postgresql://mali:mali@postgres:5432/mali_one

# Redis
REDIS_URL=redis://redis:6379

# AWS S3 (us-east-1)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=mali-one-files
S3_PUBLIC_READ=false

# Gestor S3 (solo BOOTSTRAP_ADMIN_EMAIL) — mismas keys, permisos IAM ampliados
AWS_S3_MANAGER_BUCKETS=mali-assets,mali-backups,mali-one-files,tmsaws

# Uploads
UPLOAD_MAX_MB=25
# Límite de subida para screen-cast (JPG/PNG/GIF/MP4). Por defecto 50 si no se define.
# SCREEN_CAST_UPLOAD_MAX_MB=25

# Widgets — seed inicial (solo primer despliegue / entorno vacío; en producción dejar sin definir o false)
# WIDGET_SEED_ON_START=true

# Widgets — Google Maps (educación)
GOOGLE_MAPS_API_KEY=

# Widgets — Google Calendar (educación; restricción por referrer en el navegador)
GOOGLE_CALENDAR_API_KEY=

# PAM — correos desde pam@mali.pe
PAM_SMTP_HOST=
PAM_SMTP_PORT=587
PAM_SMTP_SECURE=false
PAM_SMTP_USER=
PAM_SMTP_PASS=
PAM_SMTP_FROM=pam@mali.pe

# WhatsApp CRM (fuente de verdad de contactos PAM)
# Base URL del API de mali-whatsapp (sin barra final). Local: http://localhost:4000
WHATSAPP_CRM_BASE_URL=
# Mismo valor que CRM_SERVICE_TOKEN en mali-whatsapp-mvp
WHATSAPP_CRM_SERVICE_TOKEN=

# Mailing (SES) — boletines masivos PAM
SES_FROM_EMAIL=noreply@mali.pe
SES_FROM_NAME=MALI
# Usa las mismas AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION

# Bsale (Perú) — reportes Kardex
BSALE_BASE_URL=https://api.bsale.com.pe
BSALE_ACCESS_TOKEN=
